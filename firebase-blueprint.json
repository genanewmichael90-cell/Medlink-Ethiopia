{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user basic information and medical profile.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User's unique identifier." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "displayName": { "type": "string", "description": "User's full name." },
        "photoURL": { "type": "string", "format": "uri", "description": "User's profile picture URL." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["uid", "email"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Stores patient appointments with doctors.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientUid": { "type": "string" },
        "patientName": { "type": "string" },
        "patientAge": {
          "type": "object",
          "properties": {
            "years": { "type": "integer" },
            "months": { "type": "integer" },
            "days": { "type": "integer" }
          }
        },
        "specialty": { "type": "string" },
        "doctorId": { "type": "string" },
        "doctorName": { "type": "string" },
        "hospitalId": { "type": "string" },
        "hospitalName": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "completed"] },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["consult", "booking"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientUid", "patientName", "specialty", "hospitalName", "date", "time", "status", "type"]
    },
    "Prescription": {
      "title": "Prescription",
      "description": "Stores patient medical prescriptions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientUid": { "type": "string" },
        "doctorId": { "type": "string" },
        "doctorName": { "type": "string" },
        "medication": { "type": "string" },
        "dosage": { "type": "string" },
        "instructions": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientUid", "medication", "date"]
    },
    "LabResult": {
      "title": "Lab Result",
      "description": "Stores patient diagnostic lab results.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientUid": { "type": "string" },
        "centerId": { "type": "string" },
        "centerName": { "type": "string" },
        "testName": { "type": "string" },
        "result": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "final"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientUid", "testName", "date", "status"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Patient appointments."
    },
    "/prescriptions/{prescriptionId}": {
      "schema": "Prescription",
      "description": "Patient prescriptions."
    },
    "/labResults/{resultId}": {
      "schema": "LabResult",
      "description": "Patient lab results."
    }
  }
}
